# Скопируйте в .env.local и подставьте значения.
# Файл .env.local не коммитится (*.local в .gitignore).
# npm run bot и seed:supabase: загружают сначала .env, затем .env.local (локальные ключи перекрывают базовые).

# Render / npm run start:render: запустить Telegram-бот вакансий вторым процессом (long polling)
# RUN_TELEGRAM_VACANCIES_BOT=true

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Ваш chat_id: напишите боту /start, затем откройте в браузере:
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
# и найдите "chat":{"id": 123456789 — это число в TELEGRAM_CHAT_ID
TELEGRAM_CHAT_ID=

# Опционально: свой бэкенд вместо встроенного /api/lead (продакшен на статике)
# VITE_LEAD_API_URL=https://example.com/api/lead

# Публичный URL списка вакансий (JSON) для продакшена без Vite middleware
# VITE_VACANCIES_API_URL=https://example.com/api/vacancies

# Netlify: в netlify.toml уже заданы VITE_LEAD_API_URL=/api/lead и VITE_VACANCIES_API_URL=/vacancies.json
# В панели Netlify добавьте только секреты: TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID (см. docs/NETLIFY.md)

# --- Supabase (без VPS), см. docs/SUPABASE.md ---
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # только сервер/скрипты, не в Git, не VITE_
# SUPABASE_ANON_KEY=eyJ...           # опционально для Vite middleware /api/vacancies (если без VITE_)

# Файл с вакансиями (бот и GET /api/vacancies). По умолчанию: data/vacancies.json
# VACANCIES_FILE=data/vacancies.json

# Числовые Telegram user id админов бота вакансий (через запятую). См. docs/TELEGRAM_VACANCIES_BOT.md
TELEGRAM_ADMIN_IDS=
