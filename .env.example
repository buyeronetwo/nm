# Скопируйте в .env.local и подставьте значения.
# Файл .env.local не коммитится (*.local в .gitignore).

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Ваш chat_id: напишите боту /start, затем откройте в браузере:
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
# и найдите "chat":{"id": 123456789 — это число в TELEGRAM_CHAT_ID
TELEGRAM_CHAT_ID=

# Опционально: свой бэкенд вместо встроенного /api/lead (продакшен на статике)
# VITE_LEAD_API_URL=https://example.com/api/lead

# Публичный URL списка вакансий (JSON) для продакшена без Vite middleware
# VITE_VACANCIES_API_URL=https://example.com/api/vacancies

# Файл с вакансиями (бот и GET /api/vacancies). По умолчанию: data/vacancies.json
# VACANCIES_FILE=data/vacancies.json

# Числовые Telegram user id админов бота вакансий (через запятую). См. docs/TELEGRAM_VACANCIES_BOT.md
TELEGRAM_ADMIN_IDS=
